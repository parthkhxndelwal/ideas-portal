{
  "name": "solesta-26-bot",
  "version": "1.0.0",
  "description": "Telegram bot for Solesta '26 event registrations",
  "main": "dist/bot/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot/index.js",
    "dev": "ts-node src/bot/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "reconcile": "ts-node src/scripts/reconcile.ts",
    "import:students": "ts-node src/scripts/importStudents.ts",
    "import:data": "npx ts-node import/importStudents.ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "registration",
    "solesta"
  ],
  "author": "Solesta Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "nodemailer": "^6.9.12",
    "qrcode": "^1.5.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "telegraf": "^4.16.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.25",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
