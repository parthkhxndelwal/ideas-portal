# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# MongoDB Configuration (Prisma)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/solesta?retryWrites=true&w=majority

# Admin Telegram User IDs (comma-separated)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Application URL (for webhooks - not used in polling mode)
APP_URL=https://your-domain.com

# Payment Links
PAYMENT_LINK_INTERNAL=https://p.ppsl.io/PYTMPS/Ro1Qfk
PAYMENT_LINK_EXTERNAL=https://p.ppsl.io/PYTMPS/UYrQfk

# Registration Fees
FEE_KRMU=500
FEE_EXTERNAL=700

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_MAX_RETRIES=3

# Node Environment
NODE_ENV=development