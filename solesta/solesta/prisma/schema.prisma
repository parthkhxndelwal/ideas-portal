generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  telegramId            String?
  externalAppId         String?       @unique
  username              String?
  firstName             String?
  lastName               String?
  state                 String        @default("START")
  stateData             Json?
  isVerified            Boolean       @default(false)
  isKrmu                Boolean       @default(false)
  isAdmin               Boolean       @default(false)
  verifiedAt            DateTime?     @map("verified_at")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  registration          Registration?

  @@unique([telegramId], map: "users_telegramId_key")
  @@map("users")
}

model Student {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  rollNumber            String?       @map("rollNumber")
  name                  String        @map("name")
  courseAndSemester     String        @map("courseAndSemester")
  year                  String        @map("year")
  email                 String?
  createdAt             DateTime?
  updatedAt             DateTime?

  @@map("students")
}

model Otp {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  userId                String        @map("user_id")
  email                 String
  code                  String
  hashedCode            String
  expiresAt             DateTime      @map("expires_at")
  isUsed                Boolean      @default(false)
  retryCount            Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("otps")
}

model Registration {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  referenceId          String        @unique @map("reference_id")
  userId               String        @unique @map("user_id") @db.ObjectId
  telegramId           String?
  externalAppId        String?       @map("external_app_id")
  
  name                 String
  email                 String
  rollNumber           String?       @map("roll_number")
  college              String?
  course               String
  year                 String
  isKrmu               Boolean       @map("is_krmu")
  isFresher            Boolean?      @default(false) @map("is_fresher")
  
  feeAmount            Int           @map("fee_amount")
  feePaid              Boolean       @default(false) @map("fee_paid")
  paymentDate         DateTime?     @map("payment_date")
  
  qrCode              String?       @map("qr_code")
  qrSentTelegram     Boolean       @default(false) @map("qr_sent_telegram")
  qrSentEmail        Boolean       @default(false) @map("qr_sent_email")
  telegramRetryCount Int           @default(0) @map("telegram_retry_count")
  emailRetryCount    Int           @default(0) @map("email_retry_count")
  lastTelegramAttempt DateTime?    @map("last_telegram_attempt")
  lastEmailAttempt   DateTime?    @map("last_email_attempt")
  
  ticketSentAt        DateTime?     @map("ticket_sent_at")
  manualRegistration  Boolean       @default(false) @map("manual_registration")
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                 User          @relation(fields: [userId], references: [id])

  @@map("registrations")
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model AuditLog {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  level                 LogLevel
  action                String
  telegramId           String?       @map("telegram_id")
  message              String
  metadata             Json?
  createdAt             DateTime      @default(now())

  @@map("audit_logs")
}

model SupportTicket {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  telegramId            String        @map("telegram_id")
  name                  String
  email                 String?
  message               String
  status                String        @default("open")
  adminResponse         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("support_tickets")
}

model ApiKey {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  key         String    @unique
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@map("api_keys")
}

model Admin {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  username  String    @unique
  password  String    // bcrypt hashed
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admins")
}

model RegistrationLink {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  registrationId  String    @map("registration_id") @db.ObjectId
  token           String    @unique
  expiresAt       DateTime  @map("expires_at")
  isUsed          Boolean   @default(false) @map("is_used")
  usedAt          DateTime? @map("used_at")
  email           String
  createdAt       DateTime  @default(now())

  @@map("registration_links")
}