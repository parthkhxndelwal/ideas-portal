# QR Generation Key for Decryption
# This key should match the QR_ENCRYPTION_KEY used in:
# - solesta_bot/.env
# - approval_script/.env
# - Web/.env
# 
# The scanner uses this key to decrypt QR codes generated from:
# - Approval script (referenceId:rollNumber:referenceId format)
# - Bot-generated QRs (participant_solesta_${transactionId} format)
#
# To set up: Copy this file to .env.local and set the QR_GENERATION_KEY value
EXPO_PUBLIC_QR_GENERATION_KEY=SOLESTA26SECRETKEY2026XXXX

# Optional: API Server URL (defaults to https://solesta.krmangalam.edu.in)
# EXPO_PUBLIC_API_URL=https://solesta.krmangalam.edu.in
